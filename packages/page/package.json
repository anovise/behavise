{
  "name": "@anovise/behavise-page",
  "version": "0.1.0",
  "description": "URL visit counting and scroll position tracking for behavise",
  "author": "Reas Vyn <reasvyn@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anovise/behavise.git",
    "directory": "packages/page"
  },
  "homepage": "https://github.com/anovise/behavise#readme",
  "bugs": {
    "url": "https://github.com/anovise/behavise/issues"
  },
  "keywords": [
    "analytics",
    "behavior",
    "tracking",
    "navigation",
    "scroll",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anovise/behavise-core": "0.1.0"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
