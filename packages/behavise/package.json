{
  "name": "@anovise/behavise",
  "version": "0.1.0",
  "description": "User behavior tracking library — modular, type-safe, framework-agnostic",
  "author": {
    "name": "Reas Vyn",
    "email": "reasvyn@gmail.com",
    "url": "https://github.com/reasvyn"
  },
  "maintainers": [
    {
      "name": "Anovise",
      "url": "https://github.com/anovise"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anovise/behavise.git",
    "directory": "packages/behavise"
  },
  "homepage": "https://github.com/anovise/behavise#readme",
  "bugs": {
    "url": "https://github.com/anovise/behavise/issues"
  },
  "keywords": [
    "analytics",
    "behavior",
    "tracking",
    "ux",
    "heatmap",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anovise/behavise-core": "0.1.0",
    "@anovise/behavise-pointer": "0.1.0",
    "@anovise/behavise-page": "0.1.0",
    "@anovise/behavise-interaction": "0.1.0"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
