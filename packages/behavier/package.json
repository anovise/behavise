{
  "name": "behavier",
  "version": "0.1.0",
  "description": "User behavior tracking library — modular, type-safe, framework-agnostic",
  "author": "Reas Vyn <reasvyn@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reasvyn/behavier.git",
    "directory": "packages/behavier"
  },
  "homepage": "https://github.com/reasvyn/behavier#readme",
  "bugs": {
    "url": "https://github.com/reasvyn/behavier/issues"
  },
  "keywords": [
    "analytics",
    "behavior",
    "tracking",
    "ux",
    "heatmap",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@behavier/core": "*",
    "@behavier/pointer": "*",
    "@behavier/page": "*",
    "@behavier/interaction": "*"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
