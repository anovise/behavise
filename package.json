{
  "name": "behavise-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the behavise user behavior tracking library",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "bash scripts/deploy.sh",
    "publish": "bash scripts/publish.sh"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "tsup": "^8.4.0",
    "turbo": "^2.5.4",
    "typescript": "~5.7.3",
    "vitest": "^3.1.2"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  }
}
